# =========================
# Telegram Bot
# =========================
BOT_TOKEN=your_telegram_bot_token_here

# =========================
# MongoDB
# =========================
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database_name?retryWrites=true&w=majority&appName=YourAppName

# =========================
# Admin Panel
# =========================
ADMIN_PASSWORD=your_admin_password_here

# Optional: list of admin IDs (comma separated)
# ADMINS=123456789,987654321

# First admin (will be created automatically)
FIRST_ADMIN_ID=123456789

# Super admins (can manage other admins)
SUPER_ADMINS=123456789

# =========================
# External URLs
# =========================
RULES_URL=http://localhost:3000/rules
SUPPORT_CONTACT=@your_support_username

# =========================
# Server
# =========================
PORT=3000

# =========================
# Web App (Admin Panel)
# =========================
WEBAPP_URL=http://your-domain.com/admin

# =========================
# Bot Info
# =========================
BOT_NAME=YourBotName