# Telegram Bot Token (отримати від @BotFather)
BOT_TOKEN=your_bot_token_here

# MongoDB Connection String (отримати в MongoDB Atlas)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/bot_db?retryWrites=true&w=majority

# Admin password for web panel
ADMIN_PASSWORD=your_admin_password_here

# Admin Telegram IDs (через кому)
ADMINS=your_telegram_id

# Add First Admin
FIRST_ADMIN_ID=your_telegram_id

# Server port
PORT=3000